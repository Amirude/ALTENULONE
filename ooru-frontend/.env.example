# Copy this file to .env before running the dev server.
# Points the frontend at your running backend (see ../ooru-backend).
VITE_API_BASE_URL=https://altenulone-backend.onrender.com/api
# Production (once deployed): VITE_API_BASE_URL=https://ooru-backend.onrender.com/api

# Razorpay's public "key id" (safe to expose in frontend code — it's not the secret).
# Get this from your Razorpay dashboard; must match RAZORPAY_KEY_ID on the backend.
VITE_RAZORPAY_KEY_ID=rzp_test_placeholder

# Firebase Console -> Project Settings -> General -> "Your apps" (web app config).
# Also duplicate these same values into public/firebase-messaging-sw.js (service workers can't
# read .env files, so that file needs plain values, not import.meta.env references).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Project Settings -> Cloud Messaging -> Web Push certificates -> generate key pair
VITE_FIREBASE_VAPID_KEY=

# Google Cloud Console -> enable "Maps JavaScript API" -> Credentials -> create an API key.
# Restrict it to your domain before going live — an unrestricted key can be used by anyone who
# reads your page source.
VITE_GOOGLE_MAPS_API_KEY=
